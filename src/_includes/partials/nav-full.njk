{% set prefix = "" if isHome else "/index.html" %}
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 {{ 'nav-transparent' if (isHome or isService) else 'nav-solid' }}">
  <div class="max-w-7xl mx-auto px-5 md:px-10 h-[68px] flex items-center justify-between">
    <!-- Logo -->
    <a href="{{ '/' if isHome else '/index.html' }}" class="flex-shrink-0 cursor-pointer" aria-label="ValiaDigital - Inicio">
      {% include "partials/logo-svg.njk" %}
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {% if isService %}
      <a href="/index.html" class="nav-text text-[15px] transition-all duration-200 cursor-pointer relative">Inicio</a>
      <a href="#beneficios" class="nav-text text-[15px] transition-all duration-200 cursor-pointer relative">Beneficios</a>
      <a href="#proceso" class="nav-text text-[15px] transition-all duration-200 cursor-pointer relative">Proceso</a>
      <a href="#contacto" class="nav-text text-[15px] transition-all duration-200 cursor-pointer relative">Contacto</a>
      {% else %}
      {% for link in navigation.main %}
      {% if link.anchor == "contacto" %}
      <a href="#contacto" class="{{ 'nav-link ' if isHome }}nav-text text-[15px] transition-all duration-200 cursor-pointer relative">{{ link.label }}</a>
      {% else %}
      <a href="{{ prefix }}#{{ link.anchor }}" class="{{ 'nav-link ' if isHome }}nav-text text-[15px] transition-all duration-200 cursor-pointer relative">{{ link.label }}</a>
      {% endif %}
      {% endfor %}
      {% endif %}
    </div>

    <!-- Desktop CTA -->
    <a href="#contacto" class="hidden md:inline-block bg-brand text-white font-body text-[15px] font-medium px-6 py-2.5 rounded-lg hover:bg-brand-hover transition-colors duration-200 cursor-pointer cta-btn">Diagnóstico gratuito &rarr;</a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden p-2 cursor-pointer" aria-label="Abrir menú" aria-expanded="false">
      <svg class="w-6 h-6 nav-hamburger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</nav>
<!-- Spacer to account for fixed nav -->
<div class="{{ 'h-[68px]' if not (isHome or isService) }}"></div>
