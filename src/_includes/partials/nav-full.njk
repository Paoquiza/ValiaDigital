{% set prefix = "" if isHome else "/index.html" %}
<nav class="sticky top-0 z-50 bg-white border-b border-border-c">
  <div class="max-w-7xl mx-auto px-5 md:px-10 h-[60px] flex items-center justify-between">
    <!-- Logo -->
    <a href="{{ '/' if isHome else '/index.html' }}" class="flex-shrink-0 cursor-pointer" aria-label="ValiaDigital - Inicio">
      {% include "partials/logo-svg.njk" %}
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {% for link in navigation.main %}
      {% if link.anchor == "contacto" %}
      <a href="#contacto" class="{{ 'nav-link ' if isHome }}text-sm text-gray-500 hover:text-gray-900 transition-colors duration-200 cursor-pointer relative">{{ link.label }}</a>
      {% else %}
      <a href="{{ prefix }}#{{ link.anchor }}" class="{{ 'nav-link ' if isHome }}text-sm text-gray-500 hover:text-gray-900 transition-colors duration-200 cursor-pointer relative">{{ link.label }}</a>
      {% endif %}
      {% endfor %}
    </div>

    <!-- Desktop CTA -->
    <a href="#contacto" class="hidden md:inline-block bg-brand text-white font-body text-[13px] sm:text-sm font-medium px-6 py-3 rounded-lg hover:bg-brand-hover transition-colors duration-200 cursor-pointer cta-btn">Hablemos &rarr;</a>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="md:hidden p-2 cursor-pointer" aria-label="Abrir menú" aria-expanded="false">
      <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>
</nav>
