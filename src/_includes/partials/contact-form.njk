<section class="bg-white py-14 sm:py-20 px-5 sm:px-6 md:px-10 reveal" id="contacto">
  <div class="max-w-2xl mx-auto">
    <h2 class="font-display font-extrabold text-xl sm:text-2xl md:text-[32px] text-brand-dark tracking-tight mb-3 text-center">{{ contactTitle or "Hablemos de tu proyecto" }}</h2>
    <p class="text-[15px] text-gray-500 mb-10 text-center font-light">
      Escríbenos a <a href="mailto:{{ site.email }}" class="text-brand hover:text-brand-hover transition-colors duration-200 cursor-pointer">{{ site.email }}</a> o llena el formulario
    </p>

    <form id="contact-form" action="https://formspree.io/f/{{ site.formspreeId }}" method="POST" class="space-y-4" novalidate>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="nombre" class="block text-xs font-medium text-gray-600 mb-1.5">Nombre <span class="text-red-400">*</span></label>
          <input type="text" id="nombre" name="nombre" required aria-required="true" placeholder="Tu nombre" class="w-full border border-border-c rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-200">
          <p class="field-error">Por favor ingresa tu nombre</p>
        </div>
        <div>
          <label for="empresa" class="block text-xs font-medium text-gray-600 mb-1.5">Empresa <span class="text-red-400">*</span></label>
          <input type="text" id="empresa" name="empresa" required aria-required="true" placeholder="Tu empresa" class="w-full border border-border-c rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-200">
          <p class="field-error">Por favor ingresa tu empresa</p>
        </div>
      </div>
      <div>
        <label for="email" class="block text-xs font-medium text-gray-600 mb-1.5">Email <span class="text-red-400">*</span></label>
        <input type="email" id="email" name="email" required aria-required="true" placeholder="tu@empresa.com" class="w-full border border-border-c rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-200">
        <p class="field-error">Por favor ingresa un email válido</p>
      </div>
      <div>
        <label for="telefono" class="block text-xs font-medium text-gray-600 mb-1.5">Teléfono / WhatsApp <span class="text-gray-400 font-normal">(opcional)</span></label>
        <input type="tel" id="telefono" name="telefono" placeholder="+52 55 1234 5678" class="w-full border border-border-c rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-200">
      </div>
      <div>
        <label for="mensaje" class="block text-xs font-medium text-gray-600 mb-1.5">Mensaje <span class="text-red-400">*</span></label>
        <textarea id="mensaje" name="mensaje" required aria-required="true" rows="5" placeholder="{{ contactPlaceholder or 'Cuéntanos sobre tu proyecto' }}" class="w-full border border-border-c rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-colors duration-200 resize-vertical"></textarea>
        <p class="field-error">Por favor describe tu proyecto</p>
      </div>
      {% if contactSubject %}
      <input type="hidden" name="_subject" value="{{ contactSubject }}">
      {% endif %}
      {% if contactService %}
      <input type="hidden" name="servicio" value="{{ contactService }}">
      {% endif %}
      <button type="submit" class="w-full bg-brand text-white font-body text-base font-medium px-6 py-4 rounded-lg hover:bg-brand-hover transition-colors duration-200 cursor-pointer cta-btn">Enviar mensaje &rarr;</button>
    </form>

    <div id="form-success" class="hidden text-center py-12">
      <div class="w-14 h-14 bg-accent/10 rounded-full flex items-center justify-center mx-auto mb-4" aria-hidden="true">
        <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h3 class="font-display font-bold text-xl text-brand-dark mb-2">¡Mensaje enviado!</h3>
      <p class="text-sm text-gray-500 font-light">Nos pondremos en contacto contigo pronto.</p>
    </div>
  </div>
</section>
