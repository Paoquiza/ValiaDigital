<section class="relative py-16 sm:py-24 px-5 sm:px-6 md:px-10 reveal overflow-hidden bg-[#F7F9FB]" id="contacto">
  <div class="absolute top-[10%] right-[-8%] w-[300px] h-[300px] rounded-full bg-brand/[0.03] blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-[10%] left-[-5%] w-[250px] h-[250px] rounded-full bg-accent/[0.03] blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-5xl mx-auto relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14 items-start">

      <!-- Left: context -->
      <div class="lg:col-span-2 text-center lg:text-left lg:sticky lg:top-28">
        <p class="text-sm tracking-[0.14em] uppercase text-brand font-medium mb-3">{{ contactTitle or "Hablemos" }}</p>
        <h2 class="font-display font-extrabold text-2xl sm:text-3xl md:text-4xl text-brand-dark tracking-tight mb-5 leading-tight">Cuéntanos tu reto y te decimos cómo resolverlo</h2>
        <div class="w-16 h-1 bg-gradient-to-r from-brand to-accent rounded-full mb-6 mx-auto lg:mx-0"></div>
        <p class="text-base sm:text-lg text-gray-500 leading-relaxed mb-10">
          Completa el formulario o escríbenos directo a <a href="mailto:{{ site.email }}" class="text-brand font-medium hover:text-brand-hover transition-colors duration-200">{{ site.email }}</a>
        </p>

        <!-- Trust signals -->
        <div class="space-y-5 hidden lg:block" aria-label="Trust signals desktop">
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-brand/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brand-dark">Respuesta en menos de 24h</p>
              <p class="text-xs text-gray-400">Por WhatsApp o email</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-accent/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brand-dark">Te contacta un fundador</p>
              <p class="text-xs text-gray-400">Sin intermediarios ni vendedores</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 rounded-xl bg-brand-dark/[0.06] flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-brand-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-brand-dark">Sin compromiso de compra</p>
              <p class="text-xs text-gray-400">Si no te convence, no pasa nada</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Trust signals mobile -->
      <div class="lg:hidden flex flex-wrap justify-center gap-4 mb-2">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <span class="text-sm text-gray-500 font-medium">Respuesta en 24h</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <span class="text-sm text-gray-500 font-medium">Te contacta un fundador</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
          <span class="text-sm text-gray-500 font-medium">Sin compromiso</span>
        </div>
      </div>

      <!-- Right: form -->
      <div class="lg:col-span-3">
        <div class="bg-white rounded-2xl border border-border-c shadow-sm p-7 sm:p-9">
          <form id="contact-form" action="https://formspree.io/f/{{ site.formspreeId }}" method="POST" class="space-y-5" novalidate>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="nombre" class="block text-sm font-medium text-gray-600 mb-2">Nombre <span class="text-red-400">*</span></label>
                <input type="text" id="nombre" name="nombre" required aria-required="true" placeholder="Tu nombre" class="w-full border border-border-c rounded-xl px-4 py-3.5 text-base bg-[#F7F9FB] focus:bg-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all duration-200">
                <p class="field-error">Por favor ingresa tu nombre</p>
              </div>
              <div>
                <label for="empresa" class="block text-sm font-medium text-gray-600 mb-2">Empresa <span class="text-red-400">*</span></label>
                <input type="text" id="empresa" name="empresa" required aria-required="true" placeholder="Tu empresa" class="w-full border border-border-c rounded-xl px-4 py-3.5 text-base bg-[#F7F9FB] focus:bg-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all duration-200">
                <p class="field-error">Por favor ingresa tu empresa</p>
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-600 mb-2">Email <span class="text-red-400">*</span></label>
              <input type="email" id="email" name="email" required aria-required="true" placeholder="tu@empresa.com" class="w-full border border-border-c rounded-xl px-4 py-3.5 text-base bg-[#F7F9FB] focus:bg-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all duration-200">
              <p class="field-error">Por favor ingresa un email válido</p>
            </div>
            <div>
              <label for="telefono" class="block text-sm font-medium text-gray-600 mb-2">Teléfono / WhatsApp <span class="text-gray-400 font-normal">(opcional)</span></label>
              <input type="tel" id="telefono" name="telefono" placeholder="+52 55 1234 5678" minlength="10" maxlength="15" pattern="[\+]?[0-9\s]{10,15}" class="w-full border border-border-c rounded-xl px-4 py-3.5 text-base bg-[#F7F9FB] focus:bg-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all duration-200">
              <p class="field-error">Ingresa un número de al menos 10 dígitos</p>
            </div>
            <div>
              <label for="mensaje" class="block text-sm font-medium text-gray-600 mb-2">Mensaje <span class="text-red-400">*</span></label>
              <textarea id="mensaje" name="mensaje" required aria-required="true" rows="4" placeholder="{{ contactPlaceholder or '¿Cuál es el mayor reto tecnológico en tu empresa ahora mismo?' }}" class="w-full border border-border-c rounded-xl px-4 py-3.5 text-base bg-[#F7F9FB] focus:bg-white focus:outline-none focus:border-brand focus:ring-1 focus:ring-brand transition-all duration-200 resize-vertical"></textarea>
              <p class="field-error">Por favor describe tu proyecto</p>
            </div>
            {% if contactSubject %}
            <input type="hidden" name="_subject" value="{{ contactSubject }}">
            {% endif %}
            {% if contactService %}
            <input type="hidden" name="servicio" value="{{ contactService }}">
            {% endif %}
            <input type="hidden" name="g-recaptcha-response" id="recaptchaToken">
            <button type="submit" class="group w-full bg-brand text-white font-body text-base sm:text-lg font-semibold px-6 py-4 sm:py-5 rounded-xl hover:bg-brand-hover transition-all duration-200 cursor-pointer cta-btn shadow-lg shadow-brand/25 hover:shadow-xl hover:shadow-brand/35 hover:-translate-y-0.5 flex items-center justify-center gap-2">
              Enviar mensaje
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
            </button>
            <p class="text-center text-xs text-gray-400 mt-1">Te contacta directamente un fundador · Sin spam</p>
            <p class="text-center text-[10px] text-gray-300 mt-2">Protegido por <a href="https://www.google.com/recaptcha/about/" target="_blank" rel="noopener noreferrer" class="hover:text-gray-400 transition-colors">reCAPTCHA</a></p>
          </form>

          <!-- Phase 1: Sending animation -->
          <div id="form-sending" class="hidden">
            <div class="flex flex-col items-center justify-center py-12 sm:py-16">
              <lottie-player id="lottie-sending" src="/assets/lottie/sending.json" background="transparent" speed="1.3" style="width: 150px; height: 150px;"></lottie-player>
              <h3 class="font-display font-bold text-xl text-brand-dark mb-1 sending-fade">Enviando mensaje...</h3>
              <p class="text-sm text-gray-400 sending-fade">Esto tomará solo un momento</p>
            </div>
          </div>

          <!-- Phase 2: Success animation -->
          <div id="form-success" class="hidden">
            <div class="flex flex-col items-center justify-center py-12 sm:py-16">
              <lottie-player id="lottie-success" src="/assets/lottie/successfully.json" background="transparent" speed="0.8" style="width: 150px; height: 150px;"></lottie-player>
              <h3 class="font-display font-bold text-2xl text-brand-dark mb-3 success-fade">¡Mensaje enviado!</h3>
              <p class="text-base sm:text-lg text-gray-500 mb-2 success-fade success-fade-2">Te contactamos en menos de 24 horas.</p>
              <p class="text-sm text-gray-400 success-fade success-fade-3">Revisa tu bandeja de entrada y WhatsApp.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
