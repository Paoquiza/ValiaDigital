{% set prefix = "" if isHome else "/index.html" %}
<footer class="relative overflow-hidden py-14 sm:py-20 px-5 sm:px-6 md:px-10" style="background: linear-gradient(135deg, #0A2540 0%, #071c30 50%, #0A2540 100%)">
  <div class="absolute top-[20%] left-[-5%] w-[250px] h-[250px] rounded-full bg-brand/[0.04] blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-[10%] right-[-5%] w-[200px] h-[200px] rounded-full bg-accent/[0.03] blur-3xl pointer-events-none" aria-hidden="true"></div>
  <!-- V watermark -->
  <svg class="absolute right-[-2%] sm:right-[3%] top-1/2 -translate-y-1/2 w-[280px] sm:w-[350px] h-auto text-white/[0.05] pointer-events-none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="35 143 55 60" fill="none" preserveAspectRatio="xMidYMid meet">
    <g><g clip-path="url(#fw1)"><g clip-path="url(#fw2)"><g clip-path="url(#fw3)"><path fill="currentColor" d="M 80.636719 146.597656 L 91.230469 152.835938 L 62.828125 201.082031 L 52.238281 194.847656 Z"/></g></g></g><g clip-path="url(#fw4)"><g clip-path="url(#fw5)"><path fill="currentColor" d="M 38.480469 148.34375 L 55.617188 148.34375 L 55.617188 168.089844 L 38.480469 168.089844 Z"/></g></g></g>
    <defs><clipPath id="fw1"><path d="M 54 148 L 89 148 L 89 199 L 54 199 Z" clip-rule="nonzero"/></clipPath><clipPath id="fw2"><path d="M 80.636719 146.597656 L 91.230469 152.835938 L 62.828125 201.082031 L 52.238281 194.847656 Z" clip-rule="nonzero"/></clipPath><clipPath id="fw3"><path d="M 85.933594 149.71875 C 88.859375 151.4375 89.832031 155.207031 88.113281 158.132812 L 65.960938 195.761719 C 64.238281 198.6875 60.472656 199.664062 57.546875 197.941406 C 54.621094 196.21875 53.644531 192.453125 55.367188 189.527344 L 77.519531 151.894531 C 79.242188 148.972656 83.007812 147.996094 85.933594 149.71875 Z" clip-rule="nonzero"/></clipPath><clipPath id="fw4"><path d="M 38.480469 148.34375 L 55.617188 148.34375 L 55.617188 168.089844 L 38.480469 168.089844 Z" clip-rule="nonzero"/></clipPath><clipPath id="fw5"><path d="M 47.050781 148.34375 C 42.316406 148.34375 38.480469 152.761719 38.480469 158.214844 C 38.480469 163.664062 42.316406 168.082031 47.050781 168.082031 C 51.78125 168.082031 55.617188 163.664062 55.617188 158.214844 C 55.617188 152.761719 51.78125 148.34375 47.050781 148.34375 Z" clip-rule="nonzero"/></clipPath></defs>
  </svg>

  <div class="max-w-6xl mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8 mb-12">

      <!-- Col 1: Logo + description -->
      <div class="md:col-span-5">
        <a href="{{ '/' if isHome else '/index.html' }}" class="inline-block mb-4 text-white" aria-label="ValiaDigital">
          {% include "partials/logo-svg.njk" %}
        </a>
        <p class="text-sm text-muted leading-relaxed max-w-sm mb-6">{{ site.description }}</p>
        <div class="flex gap-3">
          <a href="{{ site.linkedin }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-9 h-9 rounded-lg bg-white/[0.06] border border-white/[0.08] flex items-center justify-center hover:bg-brand/20 hover:border-brand/30 transition-all duration-300">
            <svg class="w-4 h-4 text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-lg bg-white/[0.06] border border-white/[0.08] flex items-center justify-center hover:bg-brand/20 hover:border-brand/30 transition-all duration-300">
            <svg class="w-4 h-4 text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Links rápidos -->
      <div class="md:col-span-3">
        <p class="text-xs font-semibold text-[#F0F8FF]/40 uppercase tracking-[0.14em] mb-5">Enlaces</p>
        <nav class="flex flex-col gap-3" aria-label="Footer links">
          {% for link in navigation.main %}
          {% if link.anchor == "contacto" %}
          <a href="#contacto" class="text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">{{ link.label }}</a>
          {% else %}
          <a href="{{ prefix }}#{{ link.anchor }}" class="text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">{{ link.label }}</a>
          {% endif %}
          {% endfor %}
        </nav>
      </div>

      <!-- Col 3: Contacto -->
      <div class="md:col-span-4">
        <p class="text-xs font-semibold text-[#F0F8FF]/40 uppercase tracking-[0.14em] mb-5">Contacto directo</p>
        <nav class="flex flex-col gap-4" aria-label="Contact links">
          <a href="mailto:{{ site.email }}" class="flex items-center gap-3 text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">
            <div class="w-9 h-9 rounded-lg bg-white/[0.06] border border-white/[0.08] flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
            </div>
            {{ site.email }}
          </a>
          <a href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">
            <div class="w-9 h-9 rounded-lg bg-white/[0.06] border border-white/[0.08] flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </div>
            +52 55 6449 7601
          </a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <span class="text-sm text-muted">&copy; {% year %} ValiaDigital &mdash; <a href="{{ site.url }}" class="hover:text-[#F0F8FF] transition-colors duration-200">valiadigital.io</a></span>
      <nav class="flex gap-6" aria-label="Legal">
        <a href="/privacidad.html" class="text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">Privacidad</a>
        <a href="/terminos.html" class="text-sm text-muted hover:text-[#F0F8FF] transition-colors duration-200">Términos</a>
      </nav>
    </div>
  </div>
</footer>
