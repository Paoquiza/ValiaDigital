{
  "name": "valia-digital",
  "version": "2.0.0",
  "description": "ValiaDigital - Innovación tecnológica para PyMEs",
  "main": "tailwind.config.js",
  "scripts": {
    "clean": "rm -rf _site",
    "build:css": "tailwindcss -i src/assets/css/input.css -o _site/assets/css/styles.css --minify",
    "watch:css": "tailwindcss -i src/assets/css/input.css -o _site/assets/css/styles.css --watch",
    "build:11ty": "eleventy",
    "build": "npm run clean && npm run build:11ty && npm run build:css",
    "dev": "concurrently \"npm run watch:css\" \"eleventy --serve\"",
    "start": "npm run dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Paoquiza/ValiaDigital.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Paoquiza/ValiaDigital/issues"
  },
  "homepage": "https://github.com/Paoquiza/ValiaDigital#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^9.1.2",
    "html-minifier-terser": "^7.2.0",
    "tailwindcss": "^3.4.19"
  }
}
